et -euo pipefail

cd /opt/sys_monitor

# Start containers first
docker compose up -d --build

# Remove default Nginx site
sudo rm -f /etc/nginx/sites-enabled/default
sudo rm -f /etc/nginx/sites-available/default

# Install your HTTP config
sudo cp infra/aws/nginx.http.conf /etc/nginx/sites-available/sys-monitor
sudo ln -sf /etc/nginx/sites-available/sys-monitor /etc/nginx/sites-enabled/sys-monitor

# Validate and restart Nginx
sudo nginx -t
sudo systemctl restart nginx

# Obtain certificate
sudo certbot --nginx \
  -d sys-monitor.rundailytest.site \
  -m rundailytest@gmail.com \
  --agree-tos \
  --non-interactive \
  --redirect

# Replace with final SSL config
sudo cp infra/aws/nginx.ssl.conf /etc/nginx/sites-available/sys-monitor
sudo ln -sf /etc/nginx/sites-available/sys-monitor /etc/nginx/sites-enabled/sys-monitor

# Validate and reload
sudo nginx -t
sudo systemctl reload nginx

# Show running containers
docker ps

# Show listening ports
ss -tulnp | grep -E '3000|3001|9090|80|443'
