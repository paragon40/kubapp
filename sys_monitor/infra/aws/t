resource "aws_iam_role_policy" "sts_assume_eks" {
  name = "allow-assume-eks-cross-account"

  role = aws_iam_role.ec2_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect = "Allow"
      Action = "sts:AssumeRole"
      Resource = "arn:aws:iam::<EKS_ACCOUNT_ID>:role/sys-monitor-cross-account-role"
    }]
  })
}
