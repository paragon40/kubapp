git fetch origin main
git reset --hard origin/main

git add .
git commit -m "CI update"
git push origin main       


# See the actual Argo CD controller workload names
kubectl get deploy,statefulset -n argocd

# Restart the ApplicationSet controller (most likely what you want)
kubectl rollout restart deployment/argocd-applicationset-controller -n argocd
kubectl rollout status deployment/argocd-applicationset-controller -n argocd --timeout=300s

# Optionally restart the main application controller as well
kubectl rollout restart statefulset/argocd-application-controller -n argocd
kubectl rollout status statefulset/argocd-application-controller -n argocd --timeout=300s
