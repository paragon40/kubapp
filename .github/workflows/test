name: Test ArgoCD Image Updater Setup (update.yml replacement)

on:
  workflow_dispatch:

jobs:
  setup-image-updater:
    runs-on: ubuntu-latest
    environment: development

    steps:
      # --------------------------------
      # 1. Checkout repo
      # --------------------------------
      - name: Checkout repo
        uses: actions/checkout@v4

      # --------------------------------
      # 2. Configure AWS credentials
      # --------------------------------
      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: ${{ secrets.AWS_REGION }}

      # --------------------------------
      # 3. Setup kubeconfig (EKS)
      # --------------------------------
      - name: Setup kubeconfig
        run: |
          aws eks update-kubeconfig \
            --region ${{ secrets.AWS_REGION }} \
            --name kubapp-dev

      # --------------------------------
      # 4. Install Helm
      # --------------------------------
      - name: Install Helm
        uses: azure/setup-helm@v4

      # --------------------------------
      # 5. Add Argo Helm repo
      # --------------------------------
      - name: Add Argo Helm repo
        run: |
          helm repo add argo https://argoproj.github.io/argo-helm
          helm repo update

      # --------------------------------
      # 6. Ensure argocd namespace exists
      # --------------------------------
      - name: Ensure namespace exists
        run: |
          kubectl get ns argocd || kubectl create ns argocd

      # --------------------------------
      # 7. Install / Upgrade Image Updater
      # --------------------------------
      - name: Install ArgoCD Image Updater
        run: |
          helm upgrade --install argocd-image-updater argo/argocd-image-updater \
            -n argocd \
            --set config.registries[0].name=dockerhub \
            --set config.registries[0].api_url=https://registry-1.docker.io \
            --set config.registries[0].prefix=docker.io \
            --set config.registries[0].ping=true

      # --------------------------------
      # 8. Verify deployment
      # --------------------------------
      - name: Verify Image Updater pods
        run: |
          kubectl get pods -n argocd -l app.kubernetes.io/name=argocd-image-updater

      # --------------------------------
      # 9. Verify logs (optional debug)
      # --------------------------------
      - name: Check logs
        run: |
          kubectl logs -n argocd deploy/argocd-image-updater --tail=50 || true


kubectl create secret docker-registry regcred \
  -n argocd \
  --docker-username=YOUR_USER \
  --docker-password=YOUR_PASS


metadata:
  name: kubapp-root
  namespace: argocd
  annotations:
    argocd-image-updater.argoproj.io/image-list: |
      app=docker.io/<your-username>/<service>
      service1=docker.io/user/service1,
      service2=docker.io/user/service2
    argocd-image-updater.argoproj.io/update-strategy: latest
    argocd-image-updater.argoproj.io/write-back-method: git
    argocd-image-updater.argoproj.io/app.helm.image-name: image.repository
    argocd-image-updater.argoproj.io/write-back-method: git
    argocd-image-updater.argoproj.io/git-branch: main


- name: Create snapshot tag immediately after each successfuly update/deploy
  run: |
    TAG="deploy-$(date +%Y%m%d-%H%M%S)"
    git config user.name "github-actions"
    git config user.email "github-actions@github.com"

    git tag -a "$TAG" -m "Auto snapshot $TAG"
    git push origin "$TAG"

- name: Save snapshot metadata
  run: |
    mkdir -p snapshot
    echo "{
      \"tag\": \"$TAG\",
      \"commit\": \"$(git rev-parse HEAD)\"
    }" > snapshot/state.json

- name: Upload snapshot artifact
  uses: actions/upload-artifact@v4
  with:
    name: gitops-snapshot
    path: snapshot/state.json
