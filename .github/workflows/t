      - name: Delete Old Registry
        env:
        run: |
          for each in $(find artifacts/. -type f -name "*.json" ); then
            bash scripts/validate_registry.sh "$each"
          fi

          if [[ "$RESULT" == "success" ]]; then
            rm -rf temp
            rm -rf artifacts
            echo "✅ Old registry removed.."
          else
            echo "❌ Registry files from downloaded artifacts failed structural"
            exit 1
          fi
