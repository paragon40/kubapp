
# Include Explicit ordering for destroy and create!!!!!!!!

- name: Wait for ENI cleanup
  run: |
    VPC_ID=$(terraform output -raw vpc_id)

    for i in {1..60}; do
      COUNT=$(aws ec2 describe-network-interfaces \
        --filters Name=vpc-id,Values=$VPC_ID \
        --query "length(NetworkInterfaces)" \
        --output text)

      echo "ENIs remaining: $COUNT"

      if [ "$COUNT" -eq 0 ]; then
        echo "Clean"
        exit 0
      fi

      sleep 30
    done

    exit 1

- name: Wait for all subnets to be clean (ENIs)
  run: |
    IFS=',' read -ra SUBNET_ARRAY <<< "$SUBNETS"

    for SUBNET_ID in "${SUBNET_ARRAY[@]}"; do
      echo "Checking subnet: $SUBNET_ID"

      for i in {1..60}; do
        COUNT=$(aws ec2 describe-network-interfaces \
          --filters "Name=subnet-id,Values=$SUBNET_ID" \
          --query "length(NetworkInterfaces)" \
          --output text)

        echo "$SUBNET_ID → ENIs: $COUNT"

        if [ "$COUNT" -eq 0 ]; then
          break
        fi

        sleep 30
      done

      if [ "$COUNT" -ne 0 ]; then
        echo "Timeout on subnet $SUBNET_ID"
        exit 1
      fi
    done

    echo "All subnets are clean"


- name: Wait for VPC cleanup
  run: |
    VPC_ID=$(terraform output -raw vpc_id)

    for i in {1..60}; do
      COUNT=$(aws ec2 describe-network-interfaces \
        --filters "Name=vpc-id,Values=$VPC_ID" \
        --query "length(NetworkInterfaces)" \
        --output text)

      echo "Remaining ENIs in VPC: $COUNT"

      if [ "$COUNT" -eq 0 ]; then
        echo "VPC is clean"
        exit 0
      fi

      sleep 30
    done

    echo "Timeout waiting for VPC cleanup"
    exit 1
