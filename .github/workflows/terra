infra_plan:
  if: ${{ github.event.inputs.action == 'apply' }}
  name: Infra - Plan
  runs-on: ubuntu-latest

  steps:
    - uses: actions/checkout@v4

    - uses: hashicorp/setup-terraform@v3

    - name: Install SOPS
      run: |
        curl -L -o sops https://github.com/getsops/sops/releases/download/v3.9.0/sops-v3.9.0.linux.amd64
        chmod +x sops
        sudo mv sops /usr/local/bin/sops

    - uses: aws-actions/configure-aws-credentials@v4
      with:
        role-to-assume: ${{ secrets.AWS_ROLE_ARN }}
        aws-region: us-east-1

    - name: Set ENV
      run: echo "ENV=${{ github.event.inputs.env }}" >> $GITHUB_ENV

    - name: Terraform Init
      working-directory: iac/infra
      run: terraform init -reconfigure -backend-config="envs/${ENV}/backend.hcl"

    - name: Terraform Validate
      working-directory: iac/infra
      run: terraform validate

    - name: Load tfvars
      working-directory: iac/infra
      run: sops -d envs/${ENV}/infra.tfvars.enc > infra.tfvars

    - name: Terraform Plan
      working-directory: iac/infra
      run: terraform plan -out=infra.plan -var-file=infra.tfvars

infra_apply:
  if: ${{ github.event.inputs.action == 'apply' }}
  name: Infra - Apply
  needs: infra_plan
  runs-on: ubuntu-latest
  environment: ${{ github.event.inputs.env }}

  steps:
    - uses: actions/checkout@v4

    - uses: hashicorp/setup-terraform@v3

    - name: Install SOPS
      run: |
        curl -L -o sops https://github.com/getsops/sops/releases/download/v3.9.0/sops-v3.9.0.linux.amd64
        chmod +x sops
        sudo mv sops /usr/local/bin/sops

    - uses: aws-actions/configure-aws-credentials@v4
      with:
        role-to-assume: ${{ secrets.AWS_ROLE_ARN }}
        aws-region: us-east-1

    - name: Set ENV
      run: echo "ENV=${{ github.event.inputs.env }}" >> $GITHUB_ENV

    - name: Init
      working-directory: iac/infra
      run: terraform init -reconfigure -backend-config="envs/${ENV}/backend.hcl"

    - name: Load tfvars
      working-directory: iac/infra
      run: sops -d envs/${ENV}/infra.tfvars.enc > infra.tfvars

    - name: Apply Infra
      working-directory: iac/infra
      run: terraform apply -auto-approve -var-file=infra.tfvars


